# Backend Environment Variables Template
# Copy this file to .env.development or .env.production and update values

# Database Configuration
# For local development: postgresql://simple_user:simple_password@localhost:5432/simple_invoicing
# For Docker: postgresql://simple_user:simple_password@db:5432/simple_invoicing
DATABASE_URL=postgresql://simple_user:simple_password@localhost:5432/simple_invoicing

# JWT Configuration
# Use a strong, random string for production (minimum 32 characters)
SECRET_KEY=dev-secret-key-change-in-production

# JWT Algorithm
ALGORITHM=HS256

# Token expiration in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Debug mode (true for development, false for production)
DEBUG=true

# Optional: Logging level (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO

# Optional: CORS allowed origins (comma-separated)
# CORS_ORIGINS=http://localhost:5173,https://invoicing.nikhilbhatia.com

# Optional: Shortcut catalog JSON file path
# SHORTCUTS_CONFIG_PATH=/absolute/path/to/shortcuts.json

# Optional: Application environment
# ENVIRONMENT=development
